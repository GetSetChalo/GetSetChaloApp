    <!--
        YELLOW DOTS — 12 dots evenly at 30° intervals ON the orange ring (r=84)
        Positions: cx = 100 + 84*sin(angle), cy = 100 - 84*cos(angle)
        0°   → (100.00,  16.00)
        30°  → (142.00,  27.00)
        60°  → (172.74,  58.00)
        90°  → (184.00, 100.00)
        120° → (172.74, 142.00)
        150° → (142.00, 173.00)
        180° → (100.00, 184.00)
        210° → ( 58.00, 173.00)
        240° → ( 27.26, 142.00)
        270° → ( 16.00, 100.00)
        300° → ( 27.26,  58.00)
        330° → ( 58.00,  27.00)
    -->
    <!-- 0° top -->
    <path android:pathData="M100,16 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 30° top-right -->
    <path android:pathData="M142,27 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 60° right-top -->
    <path android:pathData="M173,58 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 90° right -->
    <path android:pathData="M184,100 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 120° right-bottom -->
    <path android:pathData="M173,142 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 150° bottom-right -->
    <path android:pathData="M142,173 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 180° bottom -->
    <path android:pathData="M100,184 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 210° bottom-left -->
    <path android:pathData="M58,173 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 240° left-bottom -->
    <path android:pathData="M27,142 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 270° left -->
    <path android:pathData="M16,100 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 300° left-top -->
    <path android:pathData="M27,58 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>
    <!-- 330° top-left -->
    <path android:pathData="M58,27 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" android:fillColor="#EAB308"/>

