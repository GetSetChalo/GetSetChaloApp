<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/checkout_bg_modal"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏛️"
        android:textSize="36sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BOOKING RESERVED!"
        android:textColor="@color/checkout_gold"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kindly pay the required amount on or before"
        android:textColor="@color/checkout_text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvDeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="05/04/2026"
        android:textColor="@color/checkout_white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvConfirmMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="to confirm your stay at The Taj Palace, Agra."
        android:textColor="@color/checkout_text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnPayNow"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Proceed to Pay Now"
        android:textColor="@color/checkout_bg_dark"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/checkout_bg_button_gold"
        android:stateListAnimator="@null"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/btnPayLater"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="I'll pay later"
        android:textColor="@color/checkout_text_hint"
        android:textSize="12sp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
