<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/mat_button_card_bg"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/mat_baseline_access_time_24"
        android:tint="@color/mat_accent"
        android:layout_marginEnd="12dp" />

    <TextView
        android:id="@+id/tvRecentCityName"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:text="City Name"
        android:textColor="@color/mat_textPrimary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Explore ➔"
        android:textColor="@color/mat_accent"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
