<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_booking_summary.xml  –  Dark-theme Booking Summary Screen
    Matches the #16082C / #21113D / gold palette from HotelDetailActivity.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hd_bg">

    <!-- ══════════════════════════════════════════════════════
         TOOLBAR
         ══════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/hd_card_bg"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_summary"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/hd_card_bg"
            app:navigationIcon="@drawable/ic_arrow_back_white"
            app:navigationIconTint="@color/hd_gold"
            app:title="Booking Summary"
            app:titleTextColor="@color/hd_gold" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════════════════
         SCROLLABLE BODY
         ══════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── Header ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOOKING DETAILS"
                android:textColor="@color/hd_gold"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="16dp" />

            <!-- ── Summary Card ───────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/hd_card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/hd_separator"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Hotel Name -->
                    <include layout="@layout/item_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/row_hotel_name" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/hd_separator" />

                    <!-- Price -->
                    <include layout="@layout/item_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/row_price" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/hd_separator" />

                    <!-- Address -->
                    <include layout="@layout/item_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/row_address" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/hd_separator" />

                    <!-- Room Type -->
                    <include layout="@layout/item_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/row_room_type" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/hd_separator" />

                    <!-- AC Status -->
                    <include layout="@layout/item_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/row_ac_status" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/hd_separator" />

                    <!-- Travelers -->
                    <include layout="@layout/item_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/row_travelers" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/hd_separator" />

                    <!-- Check-In -->
                    <include layout="@layout/item_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/row_check_in" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/hd_separator" />

                    <!-- Check-Out -->
                    <include layout="@layout/item_summary_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/row_check_out" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Confirm Button ──────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="PROCEED TO CHECKOUT"
                android:textColor="#1A0030"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                app:backgroundTint="@color/hd_gold_btn"
                app:cornerRadius="8dp"
                app:elevation="4dp" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
