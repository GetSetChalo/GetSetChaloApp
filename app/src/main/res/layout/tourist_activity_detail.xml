<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#2D0B4E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#2D0B4E">

        <ImageButton
            android:id="@+id/btnDetailBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/tourist_bg_back_btn"
            android:src="@drawable/tourist_ic_back"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Package Details"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full itinerary &amp; inclusions"
                android:textColor="#9B8FC0"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E1650"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="#2D0B4E">

                <TextView
                    android:id="@+id/tvDetailEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="56sp"
                    android:text="🏯" />

                <TextView
                    android:id="@+id/tvDetailDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/tourist_bg_duration_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:text="3N / 4D" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Package Name"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.2" />

                <TextView
                    android:id="@+id/tvDetailRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="4.8 ★"
                    android:textColor="#F5A623"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvDetailTags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/tourist_bg_tag"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:text="Heritage • Forts"
                    android:textColor="#A78BFA"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/tourist_bg_price_box"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDetailPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹8,499"
                            android:textColor="#F5A623"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="per person (all inclusive)"
                            android:textColor="#6B5FA0"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="WHAT'S INCLUDED"
                    android:textColor="#C4B8E8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:id="@+id/inclusionContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/tourist_bg_card"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="12dp"
                    android:text="DAY-BY-DAY ITINERARY"
                    android:textColor="#C4B8E8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:id="@+id/itineraryContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
                    
                <!-- TOTAL TRAVELLERS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TOTAL TRAVELLERS :"
                        android:textColor="@color/hd_gold"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <!-- Stepper: [ – ]  01  [ + ] -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_stepper_border"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <ImageButton
                            android:id="@+id/btn_travelers_minus"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_minus"
                            android:tint="@color/hd_gold"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Decrease travellers" />

                        <TextView
                            android:id="@+id/tv_travelers_count"
                            android:layout_width="42dp"
                            android:layout_height="wrap_content"
                            android:text="01"
                            android:textColor="@color/hd_text_main"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <ImageButton
                            android:id="@+id/btn_travelers_plus"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@android:drawable/ic_input_add"
                            android:tint="@color/hd_gold"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Increase travellers" />

                    </LinearLayout>
                </LinearLayout>

                <!-- START DATE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="START DATE :"
                    android:textColor="@color/hd_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/layout_start_date"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_date_picker_outline"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_start_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Select date"
                        android:textColor="@color/hd_text_main"
                        android:textSize="13sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/arrow_down_float"
                        android:tint="@color/hd_gold"
                        android:contentDescription="Pick date" />

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBookNow"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/tourist_bg_button"
                    android:text="PROCEED TO CHECKOUT"
                    android:textColor="#2A1060"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
