<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ta_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ta_bg_gradient"
    tools:context=".Register">

    <!-- ===== ROTATING BACKGROUND WHEEL ===== -->
    <ImageView
        android:id="@+id/ta_bgWheel2"
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_gravity="center"
        android:alpha="0.3"
        android:src="@drawable/mat_mandala_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.444" />



    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ===== HEADER: Logo + Brand Name ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="40dp"
            android:paddingBottom="20dp">

            <!-- GetSetChalo Logo -->
            <ImageView
                android:id="@+id/mat_splashLogo"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:src="@drawable/mat_splash_logo"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.444" />

            <!-- Brand Name: Get(white) Set(yellow) Chalo(white) in Playfair Display Bold -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ta_nunito_extrabold"
                    android:text="Get"
                    android:textColor="@color/ta_text_white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ta_nunito_extrabold"
                    android:text="Set"
                    android:textColor="#FFD700"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ta_nunito_extrabold"
                    android:text="Chalo"
                    android:textColor="@color/ta_text_white"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.15"
                android:text="EXPLORE INCREDIBLE INDIA"
                android:textColor="@color/ta_gold"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- ===== AUTH CARD ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/ta_bg_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── Tab Switcher ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/ta_bg_tab_container"
                android:orientation="horizontal"
                android:padding="4dp">

                <!-- Login Tab (INACTIVE) -->
                <TextView
                    android:id="@+id/ta_tabLogin"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="Login"
                    android:textColor="@color/ta_tab_inactive_text"
                    android:textSize="15sp" />

                <!-- Register Tab (ACTIVE) -->
                <TextView
                    android:id="@+id/ta_tabRegister"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/ta_bg_tab_active"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Register"
                    android:textColor="@color/ta_text_white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Register Heading ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="serif"
                android:text="Create Account"
                android:textColor="@color/ta_gold"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:text="Join us and start exploring incredible India"
                android:textColor="@color/ta_text_subtitle"
                android:textSize="13sp" />

            <!-- ── Full Name Field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="FULL NAME"
                android:textColor="@color/ta_text_label"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/ta_bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textColor="@color/ta_input_icon"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/ta_fullname"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:fontFamily="sans-serif"
                    android:hint="Enter your full name"
                    android:inputType="textPersonName"
                    android:textColor="@color/ta_text_white"
                    android:textColorHint="@color/ta_text_hint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── Email Field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="EMAIL"
                android:textColor="@color/ta_text_label"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/ta_bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉"
                    android:textColor="@color/ta_input_icon"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/ta_email"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:fontFamily="sans-serif"
                    android:hint="Enter your email"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/ta_text_white"
                    android:textColorHint="@color/ta_text_hint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── Password Field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="PASSWORD"
                android:textColor="@color/ta_text_label"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/ta_bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textColor="@color/ta_input_icon"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/ta_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:fontFamily="sans-serif"
                    android:hint="Create a password"
                    android:inputType="textPassword"
                    android:textColor="@color/ta_text_white"
                    android:textColorHint="@color/ta_text_hint"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/ta_togglePasswordVisibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👁"
                    android:textColor="@color/ta_input_icon"
                    android:textSize="18sp" />
            </LinearLayout>

            <!-- Password strength hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:text="Min. 8 characters with a number &amp; special character"
                android:textColor="@color/ta_text_or"
                android:textSize="11sp" />

            <!-- ── Phone Field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="PHONE NUMBER"
                android:textColor="@color/ta_text_label"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/ta_bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱"
                    android:textColor="@color/ta_input_icon"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/ta_phone"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:fontFamily="sans-serif"
                    android:hint="+91 Enter phone number"
                    android:inputType="phone"
                    android:textColor="@color/ta_text_white"
                    android:textColorHint="@color/ta_text_hint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── Terms & Conditions ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/ta_termsCheckbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:button="@drawable/ta_checkbox_selector" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="I agree to the Terms &amp; Conditions and Privacy Policy"
                    android:textColor="@color/ta_text_subtitle"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ── Register Button ── -->
            <Button
                android:id="@+id/ta_loginbtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/ta_bg_btn_gold"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:text="Create Account"
                android:textColor="@color/ta_card_bg_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- ── OR Divider ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/ta_divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="sans-serif"
                    android:text="or sign up with"
                    android:textColor="@color/ta_text_or"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/ta_divider" />
            </LinearLayout>

            <!-- ── Google Sign-Up Button ── -->
            <LinearLayout
                android:id="@+id/ta_googleSignUp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/ta_bg_btn_google"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="G"
                    android:textColor="#EA4335"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Sign up with Google"
                    android:textColor="@color/ta_text_white"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ── Login link ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="Already registered? "
                    android:textColor="@color/ta_text_subtitle"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/ta_createtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Login Here"
                    android:textColor="@color/ta_gold"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
        <!-- End Card -->

        <!-- ── Progress Bar ── -->
        <ProgressBar
            android:id="@+id/ta_progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:indeterminateTint="@color/ta_gold"
            android:visibility="invisible" />

    </LinearLayout>
    </ScrollView>

</FrameLayout>