<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/td_colorBackground">

    <!-- ═══════════════════ HEADER BAR ═══════════════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="@drawable/td_bg_header_back"
            android:src="@drawable/td_ic_back_arrow"
            android:scaleType="center"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="DESTINATION"
            android:textColor="@color/td_colorGold"
            android:textSize="16sp"
            android:fontFamily="serif"
            android:letterSpacing="0.15"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- ═══════════════════ SCROLLABLE CONTENT ═══════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Hero Image with Overlays ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">

                <ImageView
                    android:id="@+id/imgHero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/td_taj_mahal_hero"
                    android:contentDescription="Taj Mahal" />

                <!-- UNESCO Badge (top-right overlay) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/td_bg_unesco_badge"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:text="UNESCO HERITAGE"
                    android:textColor="@color/td_colorGold"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium" />

                <!-- Rating Badge (bottom-right overlay) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/td_bg_rating_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="★ 4.9"
                    android:textColor="@color/td_colorRatingText"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- ── Padded Content Area ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <!-- Title: Taj Mahal -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Taj Mahal"
                    android:textColor="@color/td_colorGold"
                    android:textSize="34sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <!-- Location Row: dot + city -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/td_bg_gold_dot" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Agra, Uttar Pradesh, India"
                        android:textColor="@color/td_colorTextPrimary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp"
                    android:text="Dharmapuri, Forest Colony, Tajganj, Agra \u2014 282001"
                    android:textColor="@color/td_colorTextSecondary"
                    android:textSize="12sp" />

                <!-- OPEN IN MAP Button -->
                <Button
                    android:id="@+id/btnOpenInMap"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/td_bg_map_button"
                    android:drawableStart="@drawable/td_ic_map_pin"
                    android:drawablePadding="10dp"
                    android:text="OPEN IN MAP"
                    android:textColor="@color/td_colorTextPrimary"
                    android:textSize="13sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />

                <!-- ══════════ ABOUT SECTION ══════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="ABOUT"
                    android:textColor="@color/td_colorGold"
                    android:textSize="11sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/td_colorTextPrimary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:gravity="fill_horizontal" />

                <!-- ══════════ QUICK DETAILS SECTION ══════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="QUICK DETAILS"
                    android:textColor="@color/td_colorGold"
                    android:textSize="11sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="sans-serif-medium" />

                <!-- Row 1: Built By -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:text="BUILT BY"
                        android:textColor="@color/td_colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-medium" />
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/td_colorGold" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Emperor Shah Jahan"
                        android:textColor="@color/td_colorTextPrimary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Row 2: Completed -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:text="COMPLETED"
                        android:textColor="@color/td_colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-medium" />
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/td_colorGold" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="1653 AD"
                        android:textColor="@color/td_colorTextPrimary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Row 3: UNESCO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:text="UNESCO"
                        android:textColor="@color/td_colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-medium" />
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/td_colorGold" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="World Heritage Site (1983)"
                        android:textColor="@color/td_colorTextPrimary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Row 4: Open -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:text="OPEN"
                        android:textColor="@color/td_colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-medium" />
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/td_colorGold" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Sunrise to Sunset (Fri closed)"
                        android:textColor="@color/td_colorTextPrimary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Row 5: Entry Fee -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:text="ENTRY FEE"
                        android:textColor="@color/td_colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-medium" />
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/td_colorGold" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="\u20b950 (Indian) \u00b7 \u20b91100 (Foreign)"
                        android:textColor="@color/td_colorTextPrimary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- ══════════ VISITOR TIPS SECTION ══════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="VISITOR TIPS"
                    android:textColor="@color/td_colorGold"
                    android:textSize="11sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="sans-serif-medium" />

                <!-- Tip Card 1: Best Time to Visit -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="top">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/td_bg_icon_sunrise"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/td_ic_sunrise"
                            android:contentDescription="Sunrise" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/td_tip_time_title"
                            android:textColor="@color/td_colorGold"
                            android:textSize="14sp"
                            android:fontFamily="serif"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/td_tip_time_desc"
                            android:textColor="@color/td_colorTextSecondary"
                            android:textSize="13sp"
                            android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tip Card 2: Ideal Season -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="top">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/td_bg_icon_season"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/td_ic_calendar"
                            android:contentDescription="Calendar" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/td_tip_season_title"
                            android:textColor="@color/td_colorGold"
                            android:textSize="14sp"
                            android:fontFamily="serif"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/td_tip_season_desc"
                            android:textColor="@color/td_colorTextSecondary"
                            android:textSize="13sp"
                            android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tip Card 3: Photography Tip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="top">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/td_bg_icon_camera"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/td_ic_camera"
                            android:contentDescription="Camera" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/td_tip_photo_title"
                            android:textColor="@color/td_colorGold"
                            android:textSize="14sp"
                            android:fontFamily="serif"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/td_tip_photo_desc"
                            android:textColor="@color/td_colorTextSecondary"
                            android:textSize="13sp"
                            android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tip Card 4: What to Wear -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="top">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/td_bg_icon_shoe"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/td_ic_shoe"
                            android:contentDescription="Shoe" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/td_tip_wear_title"
                            android:textColor="@color/td_colorGold"
                            android:textSize="14sp"
                            android:fontFamily="serif"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/td_tip_wear_desc"
                            android:textColor="@color/td_colorTextSecondary"
                            android:textSize="13sp"
                            android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tip Card 5: Entry & Tickets -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/td_bg_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="top">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/td_bg_icon_ticket"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/td_ic_ticket"
                            android:contentDescription="Ticket" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/td_tip_tickets_title"
                            android:textColor="@color/td_colorGold"
                            android:textSize="14sp"
                            android:fontFamily="serif"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/td_tip_tickets_desc"
                            android:textColor="@color/td_colorTextSecondary"
                            android:textSize="13sp"
                            android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
            <!-- end padded content -->

        </LinearLayout>
        <!-- end scroll inner column -->

    </androidx.core.widget.NestedScrollView>

</LinearLayout>