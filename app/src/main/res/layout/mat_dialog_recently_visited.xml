<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/mat_primary"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:minWidth="300dp">

    <!-- Header with Close/Back Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/dialogCloseBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/td_ic_back_arrow"
            android:tint="@color/mat_accent"
            android:scaleType="centerInside"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Recently Visited"
            android:textColor="@color/mat_textPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- List of Cities -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/recentCitiesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="4dp" />

    </ScrollView>

    <!-- Empty State -->
    <TextView
        android:id="@+id/recentEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No cities visited recently."
        android:textColor="@color/mat_textSecondary"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:visibility="gone" />

</LinearLayout>
