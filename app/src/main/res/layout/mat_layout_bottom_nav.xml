<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mat_bottomNav"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:layout_alignParentBottom="true"
    android:background="#2D0B4E"
    android:orientation="horizontal"
    android:weightSum="4"
    android:paddingTop="8dp"
    android:elevation="8dp">

    <LinearLayout
        android:id="@+id/mat_homeBtn"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/mat_home_icon" />

        <TextView
            android:id="@+id/mat_labelHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="#FFB74D"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/mat_bookingsBtn"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="💵"
            android:textSize="16sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/mat_labelBookings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Bookings"
            android:textColor="#FFB74D"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/mat_rewardsBtn"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="✨"
            android:textSize="16sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/mat_labelRewards"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reward Points"
            android:textColor="#FFB74D"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/mat_profileBtn"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/mat_profile_icon" />

        <TextView
            android:id="@+id/mat_labelProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textColor="#FFB74D"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>


