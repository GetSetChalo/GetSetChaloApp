<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/td_bg_destination_card"
    android:layout_marginBottom="18dp"
    android:clipToOutline="true">

    <!-- Hero Image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="190dp">

        <ImageView
            android:id="@+id/ivHeroImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/td_taj_mahal_hero"
            android:contentDescription="Destination Image" />

        <!-- Rating badge bottom-right -->
        <TextView
            android:id="@+id/tvRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="10dp"
            android:background="@drawable/td_bg_rating_badge"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="★ 4.9"
            android:textColor="@color/td_colorRatingText"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- UNESCO badge top-right -->
        <TextView
            android:id="@+id/tvUnesco"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="10dp"
            android:background="@drawable/td_bg_unesco_badge"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="UNESCO"
            android:textColor="@color/td_colorGold"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Card Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Destination Name"
            android:textColor="@color/td_colorGold"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">
            
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/td_bg_gold_dot" />
                
            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:text="Location Address"
                android:textColor="@color/td_colorTextSecondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            android:background="@color/td_colorCardBorder" />

        <!-- Price + Button Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/tvPriceTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENTRY FEE"
                    android:textColor="@color/td_colorTextSecondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium" />
                    
                <TextView
                    android:id="@+id/tvPriceRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹50 / ₹1100"
                    android:textColor="@color/td_colorGold"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="3dp" />
                    
                <TextView
                    android:id="@+id/tvPriceSubtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Indian / Foreign"
                    android:textColor="@color/td_colorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSelect"
                android:layout_width="110dp"
                android:layout_height="44dp"
                android:background="@drawable/td_bg_select_button"
                android:text="SELECT"
                android:textColor="#0B0B1E"
                android:textSize="13sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:elevation="0dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
